{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "kind",
    "containers"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "Deployment",
        "StatefulSet",
        "Job",
        "CronJob"
      ]
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 0
    },
    "schedule": {
      "type": "string",
      "minLength": 1
    },
    "restartPolicy": {
      "type": "string",
      "enum": [
        "Always",
        "OnFailure",
        "Never"
      ]
    },
    "concurrencyPolicy": {
      "type": "string",
      "enum": [
        "Allow",
        "Forbid",
        "Replace"
      ]
    },
    "backoffLimit": {
      "type": "integer",
      "minimum": 0
    },
    "parallelism": {
      "type": "integer",
      "minimum": 0
    },
    "completions": {
      "type": "integer",
      "minimum": 0
    },
    "completionMode": {
      "type": "string",
      "enum": [
        "NonIndexed",
        "Indexed"
      ]
    },
    "activeDeadlineSeconds": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "ttlSecondsAfterFinished": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "podFailurePolicy": {
      "type": "object"
    },
    "startingDeadlineSeconds": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "minReadySeconds": {
      "type": "integer",
      "minimum": 0
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "progressDeadlineSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "paused": {
      "type": "boolean"
    },
    "ordinalsStart": {
      "type": "integer",
      "minimum": 0
    },
    "podManagementPolicy": {
      "type": "string",
      "enum": [
        "OrderedReady",
        "Parallel"
      ]
    },
    "runtimeClassName": {
      "type": "string"
    },
    "priorityClassName": {
      "type": "string"
    },
    "schedulerName": {
      "type": "string"
    },
    "dnsPolicy": {
      "type": "string",
      "enum": [
        "ClusterFirst",
        "ClusterFirstWithHostNet",
        "Default",
        "None"
      ]
    },
    "dnsConfig": {
      "type": "object"
    },
    "readinessGates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "conditionType"
        ],
        "properties": {
          "conditionType": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "enableServiceLinks": {
      "type": "boolean"
    },
    "topologySpreadConstraints": {
      "type": "array"
    },
    "initcontainers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "image"
        ],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "restartPolicy": {
            "type": "string",
            "enum": [
              "Always"
            ]
          },
          "workingDir": {
            "type": "string"
          },
          "terminationMessagePolicy": {
            "type": "string",
            "enum": [
              "File",
              "FallbackToLogsOnError"
            ]
          },
          "terminationMessagePath": {
            "type": "string"
          },
          "stdin": {
            "type": "boolean"
          },
          "tty": {
            "type": "boolean"
          },
          "image": {
            "type": "object",
            "required": [
              "repository"
            ],
            "additionalProperties": true,
            "properties": {
              "repository": {
                "type": "string",
                "minLength": 1
              },
              "tag": {
                "type": "string"
              },
              "pullPolicy": {
                "type": "string",
                "enum": [
                  "Always",
                  "IfNotPresent",
                  "Never"
                ]
              },
              "command": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "containers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "image"
        ],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "image": {
            "type": "object",
            "required": [
              "repository"
            ],
            "additionalProperties": true,
            "properties": {
              "repository": {
                "type": "string",
                "minLength": 1
              },
              "tag": {
                "type": "string"
              },
              "pullPolicy": {
                "type": "string",
                "enum": [
                  "Always",
                  "IfNotPresent",
                  "Never"
                ]
              },
              "command": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "resizePolicy": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "resourceName",
                "restartPolicy"
              ],
              "additionalProperties": true,
              "properties": {
                "resourceName": {
                  "type": "string",
                  "enum": [
                    "cpu",
                    "memory"
                  ]
                },
                "restartPolicy": {
                  "type": "string",
                  "enum": [
                    "NotRequired",
                    "RestartContainer"
                  ]
                }
              }
            }
          },
          "workingDir": {
            "type": "string"
          },
          "terminationMessagePolicy": {
            "type": "string",
            "enum": [
              "File",
              "FallbackToLogsOnError"
            ]
          },
          "terminationMessagePath": {
            "type": "string"
          },
          "stdin": {
            "type": "boolean"
          },
          "tty": {
            "type": "boolean"
          },
          "service": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "type": {
                "type": "string",
                "enum": [
                  "ClusterIP",
                  "NodePort",
                  "LoadBalancer",
                  "ExternalName"
                ]
              },
              "ports": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "port",
                    "targetPort"
                  ],
                  "additionalProperties": true,
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "port": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    },
                    "targetPort": {
                      "anyOf": [
                        {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 65535
                        },
                        {
                          "type": "string",
                          "minLength": 1
                        }
                      ]
                    },
                    "protocol": {
                      "type": "string",
                      "enum": [
                        "TCP",
                        "UDP",
                        "SCTP"
                      ]
                    }
                  }
                }
              }
            }
          },
          "ingress": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "className": {
                "type": "string"
              },
              "hosts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "host",
                    "paths"
                  ],
                  "additionalProperties": true,
                  "properties": {
                    "host": {
                      "type": "string",
                      "minLength": 1
                    },
                    "paths": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "path",
                          "backend"
                        ],
                        "additionalProperties": true,
                        "properties": {
                          "path": {
                            "type": "string",
                            "minLength": 1
                          },
                          "pathType": {
                            "type": "string",
                            "enum": [
                              "ImplementationSpecific",
                              "Exact",
                              "Prefix"
                            ]
                          },
                          "backend": {
                            "type": "object",
                            "additionalProperties": true,
                            "properties": {
                              "port": {
                                "type": "object",
                                "additionalProperties": true,
                                "properties": {
                                  "number": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "maximum": 65535
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            {
              "type": "null"
            }
          ]
        },
        "targetMemoryUtilizationPercentage": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            {
              "type": "null"
            }
          ]
        },
        "customRules": {
          "type": "array"
        },
        "behavior": {
          "type": "object"
        }
      }
    },
    "scaledObject": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "pollingInterval": {
          "type": "integer",
          "minimum": 1
        },
        "cooldownPeriod": {
          "type": "integer",
          "minimum": 0
        },
        "idleReplicaCount": {
          "type": "integer",
          "minimum": 0
        },
        "minReplicaCount": {
          "type": "integer",
          "minimum": 0
        },
        "maxReplicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "triggers": {
          "type": "array"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "automount": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minAvailable": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "maxUnavailable": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "unhealthyPodEvictionPolicy": {
          "type": "string",
          "enum": [
            "IfHealthyBudget",
            "AlwaysAllow"
          ]
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "storageClass": {
          "type": "string"
        },
        "accessMode": {
          "type": "string",
          "enum": [
            "ReadWriteOnce",
            "ReadOnlyMany",
            "ReadWriteMany",
            "ReadWriteOncePod"
          ]
        },
        "size": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?(Ei|Pi|Ti|Gi|Mi|Ki)$"
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "claimRetentionPolicy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "whenDeleted": {
              "type": "string",
              "enum": [
                "Retain",
                "Delete"
              ]
            },
            "whenScaled": {
              "type": "string",
              "enum": [
                "Retain",
                "Delete"
              ]
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "CronJob"
          }
        }
      },
      "then": {
        "required": [
          "schedule"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "autoscaling": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "kind": {
            "const": "Deployment"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scaledObject": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "kind": {
            "const": "Deployment"
          }
        }
      }
    }
  ]
}
